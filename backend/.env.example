# Hedera operator (testnet account with keys)
OPERATOR_ID=0.0.xxxxxx
OPERATOR_KEY=302e0201...your-private-key

# Network
HEDERA_NETWORK=testnet

# Backend HTTP settings
PORT=4000
CORS_ORIGIN=http://localhost:5173

# LTV ratio for safe tokenisation (default 0.25 = 25%)
LTV_RATIO=0.25

# Optional: pre-existing HCS audit topic ID (if omitted, a new one is created on first run)
HCS_TOPIC_ID=
