const createFarm = async (formData) => {
  const res = await fetch(`${API_BASE}/api/farms`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      name: formData.name,
      location: formData.location,
      hectares: formData.acreage,
      estimatedValueGBP: formData.value
    })
  });

  const data = await res.json();
  return data;
};
